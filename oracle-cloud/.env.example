# ===================================
# Secrets - Portfolio Wesley Backend
# Oracle Cloud VM
# ===================================
# Copie este arquivo para .env e preencha com valores reais
# NUNCA commite o .env no Git!

# ----------------------------------
# API Key para autenticação via header X-API-Key
# ----------------------------------
# VOCÊ define este valor! Gere um token seguro:
#   PowerShell: [System.Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }) -as [byte[]])
#   Linux:      openssl rand -base64 32
API_KEY=GERE_UM_TOKEN_SEGURO_AQUI

# ----------------------------------
# AI Providers
# ----------------------------------
# Gemini (Primário - Mais Rápido)
# Obter em: https://aistudio.google.com
GEMINI_API_KEY=AIzaSy...

# OpenAI (Fallback)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ----------------------------------
# Email (Gmail SMTP)
# ----------------------------------
# Use sempre senha de app, NUNCA sua senha pessoal!
# Criar em: https://myaccount.google.com/apppasswords
GMAIL_USERNAME=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=email-destino@gmail.com

# ----------------------------------
# GitHub API
# ----------------------------------
# Token PAT com permissão somente leitura
# Criar em: https://github.com/settings/tokens
GITHUB_API_TOKEN=ghp_...
GITHUB_USERNAME=wmakeouthill

# ----------------------------------
# Spring Boot
# ----------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
LOG_LEVEL=INFO
FRONTEND_ENABLED=false

# ----------------------------------
# JVM (otimizado para 1GB RAM)
# ----------------------------------
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=65.0 -XX:+UseSerialGC
