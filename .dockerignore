# Keep Docker build context light. The container builds dependencies internally,
# so local generated artifacts are not needed.
.git
.github
**/node_modules
frontend/dist
frontend/.angular
backend/target
**/*.log
*.tar
*.tar.gz
*.zip

# Docs and deploy scripts do not need to enter the image context.
*.md
deploy*.ps1
deploy*.sh

# Local secrets/configs must never enter the build context.
*.env
*.key
*service-account*.json
