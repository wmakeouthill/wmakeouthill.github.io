{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "postinstall": "node ./scripts/postinstall-pdf-worker.mjs",
    "start:network": "ng serve --host 0.0.0.0 --port 4200",
    "start:local": "ng serve --host localhost --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:portfolio": "node dist/portfolio/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.24",
    "@angular/compiler": "^20.3.24",
    "@angular/core": "^20.3.24",
    "@angular/forms": "^20.3.24",
    "@angular/platform-browser": "^20.3.24",
    "@angular/platform-server": "^20.3.24",
    "@angular/router": "^20.3.24",
    "@angular/ssr": "^20.3.5",
    "@emailjs/browser": "^4.4.1",
    "@types/prismjs": "^1.26.5",
    "express": "^5.1.0",
    "marked": "^16.4.0",
    "mermaid": "^11.12.0",
    "pdfjs-dist": "^4.0.0",
    "prismjs": "^1.30.0",
    "raw-body": "^3.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.24",
    "@angular/cli": "^20.3.24",
    "@angular/compiler-cli": "^20.3.24",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  }
}
