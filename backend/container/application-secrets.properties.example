# ===========================
# 🔐 SECRETS LOCAIS (EXEMPLO)
# ===========================
#
# Este arquivo é apenas um EXEMPLO de como definir secrets locais.
# NÃO coloque chaves reais aqui. Use uma cópia chamada:
#   backend/container/configmap-secrets-local.properties
# que deve estar ignorada pelo Git.
#
# Este arquivo pode ser carregado via:
#   - Variáveis de ambiente (recomendado)
#   - spring.config.additional-location=file:./container/configmap-secrets-local.properties
#
# OpenAI (fallback)
OPENAI_API_KEY=sk-REPLACE_ME
openai.api.key=sk-REPLACE_ME

# Gemini via Vertex AI (primário)
# Aponte para um JSON externo; nunca salve a credencial no repositório.
GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/google-service-account.json
# Opcional: se vazio, usa o project_id do JSON da service account.
VERTEX_AI_PROJECT_ID=seu-project-id
VERTEX_AI_LOCATION=global

# GitHub API (Personal Access Token somente leitura)
GITHUB_API_TOKEN=ghp_REPLACE_ME

# E-mail (Gmail / SMTP)
# Use sempre senha de app, NUNCA sua senha de login.
# Para criar uma App Password: https://myaccount.google.com/apppasswords
GMAIL_USERNAME=seu-email-gmail@example.com
GMAIL_APP_PASSWORD=senha-de-app-aqui
EMAIL_RECIPIENT=seu-email-gmail@example.com
EMAIL_FROM=seu-email-gmail@example.com


